# replace NA with 0
D_smacof <- D_mat
D_smacof[is.na(D_smacof)] <- 0
# Safety: enforce zero diagonal
diag(D_smacof) <- 0
diag(W) <- 0
## Compute stress for multiple dimensionalities
# stress is a lack-of-fit measure between:
# The observed dissimilarities and the distances in the low-dimensional space (e.g., 2D)
# “How much information about the dissimilarity structure is lost when I force it into 2 dimensions?”
# If stress is low, then the 2D configuration preserves the rank order of your empirical dissimilarities well.
# If stress is high, 2D is insufficient → try 3D, 4D, etc.
# Stress < 0.05 → excellent fit
# 0.05–0.10 → good
# 0.10–0.20 → fair
# 0.20 → poor
# Try dimensions 1 to 8
dims <- 1:8
stress_tbl <- map_dfr(dims, function(k) {
fit <- smacof::mds(
delta = D_smacof,
weightmat = W,
type = "ordinal",
ndim = k
)
tibble(
ndim = k,
stress = fit$stress
)
})
stress_tbl
# plot the curve
ggplot(stress_tbl, aes(x = ndim, y = stress)) +
geom_point(size = 3) +
geom_line() +
theme_minimal(base_size = 14) +
labs(
x = "Number of dimensions",
y = "Stress",
title = "Stress vs. dimensionality (ordinal SMACOF)"
)
# Run Ordinal MDS (3D)
mds_ordinal_3d <- smacof::mds(
delta     = D_smacof,
weightmat = W,
type      = "ordinal",
ndim      = 3
)
# Run Ordinal MDS (4D)
mds_ordinal_4d <- smacof::mds(
delta     = D_smacof,
weightmat = W,
type      = "ordinal",
ndim      = 4
)
# Inspect stress
mds_ordinal_3d$stress
mds_ordinal_4d$stress
# extract coordinates, join data about stimulus
extract_mds_coords <- function(mds_fit, stim_lookup) {
as.data.frame(mds_fit$conf) %>%
rownames_to_column("stim_id") %>%
mutate(stim_id = as.integer(stim_id)) %>%
rename_with(~ paste0("D", seq_along(.)), -stim_id) %>%
left_join(stim_lookup, by = "stim_id")
}
mds_coords_3d <- extract_mds_coords(mds_ordinal_3d, stim_lookup)
mds_coords_4d <- extract_mds_coords(mds_ordinal_4d, stim_lookup)
# 3D projections
mds_coords_3d <- mds_coords_3d %>%
mutate(
hover_txt = paste0(
"ID: ", stim_id, "<br>",
"sm = ", sm, "<br>",
"ang = ", ang, "<br>",
"nv = ", nv
)
)
base_3d <- function(color_var, color_name) {
plot_ly(data = mds_coords_3d) %>%
add_markers(
x = ~D1, y = ~D2, z = ~D3,
marker = list(size = 5),
color = color_var,
hoverinfo = "text",
hovertext = ~hover_txt
)
}
# colored by curvature
base_3d(~sm, "sm")
# colored by angle
base_3d(~ang, "ang")
# colored by nv
base_3d(~nv, "nv")
library(ggimage)
mds_coords_3d <- mds_coords_3d %>%
mutate(
s_val = case_when(
sm == 0 ~ 0.0,
sm == 1 ~ 0.8,
sm == 2 ~ 1.4,
TRUE      ~ NA_real_
),
nv_str  = paste0("nv", nv),
ang_str = paste0("ang", ang),
s_str   = paste0("s", format(s_val, nsmall = 1)),
img_file = paste0("stim_", nv_str, "_", ang_str, "_", s_str, "_rot+000.png"),
img_path = file.path("figures/stimuli", img_file)  # adjust folder if needed
)
# plotting function
plot_mds_projection_img <- function(df, d1, d2, title = "") {
ggplot(df, aes(x = .data[[d1]], y = .data[[d2]])) +
geom_image(aes(image = img_path), size = 0.07) +  # tune size
theme_classic(base_size = 14) +
labs(x = d1, y = d2, title = title)
}
plot_mds_projection_img(
mds_coords_3d, "D1", "D2",
"Ordinal MDS 3D: D1 vs D2"
)
plot_mds_projection_img(
mds_coords_3d, "D1", "D3",
"Ordinal MDS 3D: D1 vs D3"
)
plot_mds_projection_img(
mds_coords_3d, "D2", "D3",
"Ordinal MDS 3D: D2 vs D3"
)
# 4D projections
# plotting function
plot_mds_projection <- function(df, d1, d2,
color_by = NULL,
title = "") {
p <- ggplot(df, aes(x = .data[[d1]], y = .data[[d2]])) +
geom_point(size = 3) +
geom_text(aes(label = stim_id),
vjust = -0.7, size = 3) +
theme_minimal(base_size = 14) +
labs(x = d1, y = d2, title = title)
if (!is.null(color_by)) {
p <- p +
geom_point(aes(color = .data[[color_by]]), size = 3) +
labs(color = color_by)
}
p
}
plot_mds_projection(mds_coords_4d, "D1", "D2", "sm",
"Ordinal MDS 4D: D1 vs D2 (sm)")
plot_mds_projection(mds_coords_4d, "D1", "D3", "nv",
"Ordinal MDS 4D: D1 vs D3 (nv)")
plot_mds_projection(mds_coords_4d, "D2", "D4", "ang",
"Ordinal MDS 4D: D2 vs D4 (ang)")
library(kableExtra)
# Correlate MDS dimensions with stimulus features
# Is this feature aligned with a particular axis?
cor_mds_features <- function(df, ndim) {
dim_cols <- paste0("D", 1:ndim)
df %>%
select(all_of(dim_cols), sm, nv, ang) %>%
mutate(across(c(sm, nv, ang), as.numeric)) %>%
cor(use = "complete.obs")
}
# 3D correlations
full_cor_matrix_3d <- cor_mds_features(mds_coords_3d, ndim = 3)
mds_dims <- paste0("D", 1:3)
features <- c("sm", "nv", "ang")
target_cor <- full_cor_matrix_3d[mds_dims, features]
target_cor %>%
as.data.frame() %>%
round(3) %>% # Standard academic precision
kable(
col.names = c("Smoothness", "NV", "Angle"),
align = "c",
booktabs = TRUE, # Professional 'booktabs' style (no vertical lines)
format = "html"  # Use "latex" if knitting to PDF
) %>%
kable_styling(
full_width = FALSE,
position = "left",
bootstrap_options = c("striped", "hover"),
font_size = 20
) %>%
add_header_above(c(" " = 1, "Stimulus Features" = 3))
# 4D correlations
full_cor_matrix_4d <- cor_mds_features(mds_coords_4d, ndim = 4)
mds_dims <- paste0("D", 1:4)
features <- c("sm", "nv", "ang")
target_cor <- full_cor_matrix_4d[mds_dims, features]
target_cor %>%
as.data.frame() %>%
round(3) %>% # Standard academic precision
kable(
col.names = c("Smoothness", "NV", "Angle"),
align = "c",
booktabs = TRUE, # Professional 'booktabs' style (no vertical lines)
format = "html"  # Use "latex" if knitting to PDF
) %>%
kable_styling(
full_width = FALSE,
position = "left",
bootstrap_options = c("striped", "hover"),
font_size = 20
) %>%
add_header_above(c(" " = 1, "Stimulus Features" = 3))
# the sign is arbitrary
# Vector fitting / projection: Project each feature as a vector through the space that maximally correlates with point positions.
coords_3d <- mds_coords_3d %>%
select(starts_with("D"))
features <- mds_coords_3d %>%
select(sm, nv, ang)
envfit_3d <- envfit(coords_3d, features, permutations = 999, choices = 1:3)
envfit_3d
coords_4d <- mds_coords_4d %>%
select(starts_with("D"))
features <- mds_coords_4d %>%
select(sm, nv, ang)
envfit_4d <- envfit(coords_4d, features, permutations = 999, choices = 1:4)
envfit_4d
# D1, D2, D3: coordinates of the fitted feature vector
#nv: mostly aligned with negative D2
#r2: strength of feature representation (proportion of variance in the feature explained by projection onto the entire MDS configuration)
# pr(>r): The probability that a random permutation of the feature values would produce an r² as large or larger than the observed one
# Extract r2 values from envfit results
r2_data <- data.frame(
feature = names(envfit_3d$vectors$r),
r2      = envfit_3d$vectors$r,      # already r²
pval    = envfit_3d$vectors$pvals
) %>%
mutate(
feature = factor(feature, levels = c("sm", "nv", "ang")),
label   = sprintf("p=%.3f", pval)
)
ggplot(r2_data, aes(x = feature, y = r2, fill = feature)) +
geom_col(width = 0.6, color = "black") +
theme_classic(base_size = 14) +
labs(
title = "Vector Fit Strength",
x = NULL, y = "r²", fill = "Feature"
) +
scale_y_continuous(expand = c(0, 0),
limits = function(lim) c(0, max(lim) * 1.2)) +
theme(legend.position = "none")
##### MDS on RDM-based participant clusters #####
# Assumes you already created:
# - participant_clusters (subj_id, cluster)
# - cluster_rdms (cluster, mean_RDM, n_subj)
# - stim_lookup (sm, nv, ang, stim_id)
# - extract_mds_coords() from your script above
# -------------------------
# Ordinal SMACOF MDS per cluster (3D + 4D, same settings as your group MDS)
# -------------------------
set.seed(4228)
run_cluster_mds <- function(D_mat_cluster, ndim = 3, type = "ordinal") {
# weight matrix: 1 = observed, 0 = missing
Wc <- ifelse(is.na(D_mat_cluster), 0, 1)
# replace NA with 0 for smacof input
Dc <- D_mat_cluster
Dc[is.na(Dc)] <- 0
# Safety: enforce zero diagonal
diag(Dc) <- 0
diag(Wc) <- 0
smacof::mds(
delta     = Dc,
weightmat = Wc,
type      = type,
ndim      = ndim
)
}
cluster_mds <- cluster_rdms %>%
mutate(
# 3D and 4D fits
mds_3d = map(mean_RDM, ~ run_cluster_mds(.x, ndim = 3, type = "ordinal")),
mds_4d = map(mean_RDM, ~ run_cluster_mds(.x, ndim = 4, type = "ordinal")),
stress_3d = map_dbl(mds_3d, ~ .x$stress),
stress_4d = map_dbl(mds_4d, ~ .x$stress),
# coords joined to stim_lookup
coords_3d = map(mds_3d, ~ extract_mds_coords(.x, stim_lookup)),
coords_4d = map(mds_4d, ~ extract_mds_coords(.x, stim_lookup))
)
cluster_mds %>%
select(cluster, n_subj, stress_3d, stress_4d)
# -------------------------
# Plot: 3D interactive scatter per cluster (Plotly)
# -------------------------
plot_cluster_mds3d <- function(df_coords, title = "") {
df_coords <- df_coords %>%
mutate(
hover_txt = paste0(
"ID: ", stim_id, "<br>",
"sm = ", sm, "<br>",
"ang = ", ang, "<br>",
"nv = ", nv
)
)
plot_ly(data = df_coords) %>%
add_markers(
x = ~D1, y = ~D2, z = ~D3,
marker = list(size = 5),
color = ~sm,  # change to ~nv or ~ang if you want
hoverinfo = "text",
hovertext = ~hover_txt
) %>%
layout(title = list(text = title))
}
# Example: view cluster 1 / 2
cluster_mds %>%
filter(cluster == "1") %>%
mutate(p = map2(coords_3d, stress_3d,
~ plot_cluster_mds3d(.x,
title = paste0("Cluster 1 MDS (3D) | stress=",
round(.y, 4))))) %>%
pull(p) %>%
.[[1]]
cluster_mds %>%
filter(cluster == "2") %>%
mutate(p = map2(coords_3d, stress_3d,
~ plot_cluster_mds3d(.x,
title = paste0("Cluster 2 MDS (3D) | stress=",
round(.y, 4))))) %>%
pull(p) %>%
.[[1]]
# -------------------------
# Optional: 2D image projection plots per cluster (if you want your ggimage style)
# -------------------------
# Requires your plot_mds_projection_img() + ggimage block earlier
# and that coords_3d include the img_path mapping (same as your earlier code).
