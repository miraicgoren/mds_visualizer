mutate(
s_val = case_when(
sm == 0 ~ 0.0,
sm == 1 ~ 0.8,
sm == 2 ~ 1.4,
TRUE    ~ NA_real_
),
nv_str  = paste0("nv", nv),
ang_str = paste0("ang", ang),
s_str   = paste0("s", format(s_val, nsmall = 1)),
img_file = paste0("stim_", nv_str, "_", ang_str, "_", s_str, "_rot+000.png"),
img_path = file.path("../Exp1_curvature/figures/stimuli", img_file)  # adjust if needed
)
# plotting function (same style as yours)
plot_mds_projection_img <- function(df, d1, d2, title = "") {
ggplot(df, aes(x = .data[[d1]], y = .data[[d2]])) +
geom_image(aes(image = img_path), size = 0.07) +  # tune size
theme_classic(base_size = 14) +
labs(x = d1, y = d2, title = title)
}
# --- make the 3 projections PER CLUSTER ---
clusters <- sort(unique(as.character(cluster_coords_3d$cluster)))
for (cl in clusters) {
dfc <- cluster_coords_3d %>% filter(cluster == cl)
print(plot_mds_projection_img(
dfc, "D1", "D2",
paste0("Cluster ", cl, " — Ordinal MDS 3D: D1 vs D2")
))
print(plot_mds_projection_img(
dfc, "D1", "D3",
paste0("Cluster ", cl, " — Ordinal MDS 3D: D1 vs D3")
))
print(plot_mds_projection_img(
dfc, "D2", "D3",
paste0("Cluster ", cl, " — Ordinal MDS 3D: D2 vs D3")
))
}
