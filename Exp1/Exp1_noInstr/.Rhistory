cluster_mds <- cluster_mds %>%
mutate(
coords_3d_img = map(coords_3d, ~ .x %>%
mutate(
s_val = case_when(
sm == 0 ~ 0.0,
sm == 1 ~ 0.8,
sm == 2 ~ 1.4,
TRUE      ~ NA_real_
),
nv_str  = paste0("nv", nv),
ang_str = paste0("ang", ang),
s_str   = paste0("s", format(s_val, nsmall = 1)),
img_file = paste0("stim_", nv_str, "_", ang_str, "_", s_str, "_rot+000.png"),
img_path = file.path("figures/stimuli", img_file)
)
)
)
# Example: D1 vs D2 image projection for each cluster
