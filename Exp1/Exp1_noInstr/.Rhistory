# -------------------------
# Optional: compare stress curve (1:8) per cluster (like your global stress plot)
# -------------------------
dims <- 1:8
cluster_stress_tbl <- cluster_rdms %>%
transmute(cluster, n_subj, mean_RDM) %>%
mutate(
stress_tbl = map(mean_RDM, function(Dc_mat) {
map_dfr(dims, function(k) {
fitk <- run_cluster_mds(Dc_mat, ndim = k, type = "ordinal")
tibble(ndim = k, stress = fitk$stress)
})
})
) %>%
select(cluster, n_subj, stress_tbl) %>%
unnest(stress_tbl)
ggplot(cluster_stress_tbl, aes(x = ndim, y = stress, group = cluster, color = cluster)) +
geom_point(size = 2) +
geom_line() +
theme_minimal(base_size = 14) +
labs(
title = "Stress vs. dimensionality (ordinal SMACOF) by cluster",
x = "Number of dimensions",
y = "Stress",
color = "Cluster"
)
conflicts_prefer(plotly::layout)
# =========================
# MDS within RDM-based participant clusters
# (run ordinal SMACOF separately on each cluster's mean RDM)
# =========================
run_cluster_mds <- function(D_cluster, ndim = 3, type = "ordinal") {
# weight matrix: 1 = observed, 0 = missing
Wc <- ifelse(is.na(D_cluster), 0, 1)
# replace NA with 0 for smacof input
Dc <- D_cluster
Dc[is.na(Dc)] <- 0
# safety
diag(Dc) <- 0
diag(Wc) <- 0
smacof::mds(
delta     = Dc,
weightmat = Wc,
type      = type,
ndim      = ndim
)
}
# 1) Compute mean RDM per cluster (you already made cluster_rdms above)
# cluster_rdms has: cluster, mean_RDM (list), n_subj
# 2) Run MDS for each cluster (3D and 4D)
cluster_mds <- cluster_rdms %>%
mutate(
mds_3d = map(mean_RDM, ~ run_cluster_mds(.x, ndim = 3, type = "ordinal")),
mds_4d = map(mean_RDM, ~ run_cluster_mds(.x, ndim = 4, type = "ordinal")),
stress_3d = map_dbl(mds_3d, ~ .x$stress),
stress_4d = map_dbl(mds_4d, ~ .x$stress)
)
cluster_mds %>% select(cluster, n_subj, stress_3d, stress_4d)
# 3) Extract coordinates + join stimulus features (reuses your extract_mds_coords)
cluster_coords_3d <- cluster_mds %>%
transmute(
cluster, n_subj,
coords = map(mds_3d, ~ extract_mds_coords(.x, stim_lookup))
) %>%
unnest(coords)
cluster_coords_4d <- cluster_mds %>%
transmute(
cluster, n_subj,
coords = map(mds_4d, ~ extract_mds_coords(.x, stim_lookup))
) %>%
unnest(coords)
# 4) Plot: 3D interactive (plotly) per cluster (colored by sm / nv / ang)
plot_cluster_3d <- function(df, cluster_id, color_col = "sm") {
dfc <- df %>% filter(cluster == cluster_id)
plot_ly(data = dfc) %>%
add_markers(
x = ~D1, y = ~D2, z = ~D3,
marker = list(size = 5),
color = dfc[[color_col]],
name = "Points"
) %>%
add_text(
x = ~D1, y = ~D2, z = ~D3,
text = ~stim_id,
textposition = "top center",
textfont = list(color = "black"),
showlegend = FALSE
) %>%
layout(title = paste0("Cluster ", cluster_id, " (n=", unique(dfc$n_subj), "): 3D MDS colored by ", color_col))
}
# Example calls (cluster values are factors like "1","2")
plot_cluster_3d(cluster_coords_3d, cluster_id = "1", color_col = "sm")
plot_cluster_3d(cluster_coords_3d, cluster_id = "2", color_col = "sm")
plot_cluster_3d(cluster_coords_3d, cluster_id = "1", color_col = "nv")
plot_cluster_3d(cluster_coords_3d, cluster_id = "2", color_col = "nv")
plot_cluster_3d(cluster_coords_3d, cluster_id = "1", color_col = "ang")
plot_cluster_3d(cluster_coords_3d, cluster_id = "2", color_col = "ang")
# 5) Plot: 4D projections (ggplot) per cluster (reuse your plot_mds_projection)
plot_cluster_4d_projection <- function(df, cluster_id, d1, d2, color_by = NULL, title = "") {
dfc <- df %>% filter(cluster == cluster_id)
plot_mds_projection(
df = dfc,
d1 = d1, d2 = d2,
color_by = color_by,
title = paste0("Cluster ", cluster_id, " (n=", unique(dfc$n_subj), "): ", title)
)
}
plot_cluster_4d_projection(cluster_coords_4d, "1", "D1", "D2", "sm",  "Ordinal MDS 4D: D1 vs D2 (sm)")
plot_cluster_4d_projection(cluster_coords_4d, "2", "D1", "D2", "sm",  "Ordinal MDS 4D: D1 vs D2 (sm)")
plot_cluster_4d_projection(cluster_coords_4d, "1", "D1", "D3", "nv",  "Ordinal MDS 4D: D1 vs D3 (nv)")
plot_cluster_4d_projection(cluster_coords_4d, "2", "D1", "D3", "nv",  "Ordinal MDS 4D: D1 vs D3 (nv)")
plot_cluster_4d_projection(cluster_coords_4d, "1", "D2", "D4", "ang", "Ordinal MDS 4D: D2 vs D4 (ang)")
plot_cluster_4d_projection(cluster_coords_4d, "2", "D2", "D4", "ang", "Ordinal MDS 4D: D2 vs D4 (ang)")
