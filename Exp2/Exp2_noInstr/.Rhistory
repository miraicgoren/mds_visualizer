full_width = FALSE,
position = "left",
bootstrap_options = c("striped", "hover"),
font_size = 20
) %>%
add_header_above(c(" " = 1, title = 3))
}
run_envfit_4d <- function(df, permutations = 999) {
coords <- df %>% select(D1, D2, D3, D4)
feats  <- df %>% select(sm, nv, rng) %>% mutate(across(everything(), as.numeric))
envfit(coords, feats, permutations = permutations, choices = 1:4)
}
extract_envfit_r2_4d <- function(envfit_obj, cluster_id) {
data.frame(
cluster = cluster_id,
feature = names(envfit_obj$vectors$r),
r2      = envfit_obj$vectors$r,   # already r²
pval    = envfit_obj$vectors$pvals
) %>%
mutate(
feature = factor(feature, levels = c("sm", "nv", "rng")),
label   = sprintf("p=%.3f", pval)
)
}
# =========================
# 1) Per-cluster 4D correlations (D1–D4 vs sm/nv/rng)
# =========================
clusters <- sort(unique(as.character(cluster_coords_4d$cluster)))
cor_tables_4d <- map(clusters, function(cl) {
dfc <- cluster_coords_4d %>% filter(cluster == cl)
full_cor <- cor_mds_features_4d(dfc, ndim = 4)
mds_dims <- paste0("D", 1:4)
feats    <- c("sm", "nv", "rng")
target_cor <- full_cor[mds_dims, feats, drop = FALSE]
list(cluster = cl, target_cor = target_cor)
})
for (obj in cor_tables_4d) {
cat("\n\n")
print(
make_cor_kable_4d(
obj$target_cor,
title = paste0("Cluster ", obj$cluster, " — Stimulus Features (4D)")
)
)
}
# =========================
# 2) Envfit per cluster (4D) + tidy r² table
# =========================
envfit_4d_by_cluster <- map(clusters, function(cl) {
dfc <- cluster_coords_4d %>% filter(cluster == cl)
run_envfit_4d(dfc, permutations = 999)
})
names(envfit_4d_by_cluster) <- clusters
r2_4d_all <- imap_dfr(envfit_4d_by_cluster, ~ extract_envfit_r2_4d(.x, cluster_id = .y))
# inspect table
r2_4d_all
# =========================
# 3) Plot r² bars per cluster (4D)
# =========================
r2_4d_all <- r2_4d_all %>%
mutate(sig = ifelse(pval < 0.01, "*", ""))
ggplot(r2_4d_all, aes(x = feature, y = r2, fill = feature)) +
geom_col(width = 0.6, color = "black") +
geom_text(aes(label = sig, y = pmin(r2 + 0.05, 0.98)), size = 6) +
facet_wrap(~ cluster, nrow = 1) +
theme_classic(base_size = 14) +
labs(
title = "Vector Fit Strength by Cluster (4D MDS)",
x = NULL, y = expression(r^2)) +
scale_y_continuous(expand = c(0, 0), limits = c(0, 1)) +
theme(legend.position = "none")
# Optional:
# envfit_4d_by_cluster[["1"]]
# envfit_4d_by_cluster[["2"]]
# note: sign is arbitrary
# =========================
# Envfit vector table helpers (4D)
# =========================
extract_envfit_table_4d <- function(envfit_obj) {
arrows <- envfit_obj$vectors$arrows %>%
as.data.frame() %>%
rownames_to_column("feature")
r2 <- envfit_obj$vectors$r
arrow_tbl <- arrows %>%
mutate(
feature = recode(feature,
sm  = "Smoothness",
nv  = "NV",
rng = "Range"
)
) %>%
select(feature, D1, D2, D3, D4)
arrow_tbl %>%
mutate(
R2 = c(r2["sm"], r2["nv"], r2["rng"])
) %>%
mutate(
across(c(D1, D2, D3, D4, R2), ~ signif(.x, 2))
)
}
make_envfit_kable_4d <- function(df, title) {
df %>%
kable(
col.names = c("", "D1", "D2", "D3", "D4", "R²"),
align = c("l", "c", "c", "c", "c", "c"),
booktabs = TRUE,
format = "html"
) %>%
kable_styling(
full_width = FALSE,
position = "left",
bootstrap_options = c("striped", "hover"),
font_size = 20
) %>%
add_header_above(c(" " = 1, title = 5))
}
envfit_tables_4d <- imap(envfit_4d_by_cluster, function(env, cl) {
tbl <- extract_envfit_table_4d(env)
list(
cluster = cl,
table = tbl
)
})
for (obj in envfit_tables_4d) {
cat("\n\n")
print(
make_envfit_kable_4d(
obj$table,
paste0("Cluster ", obj$cluster)
)
)
}
