library(dplyr)
library(jsonlite)
cluster_coords_3d <- cluster_coords_3d %>%
mutate(
nv_str  = paste0("N", nv),
rng_str = paste0("rng", rng),
s_str   = paste0("curv", sm),
img_file = paste0("circle_", rng_str, "_", nv_str, "_", s_str, "_seed7.png"),
img_path = file.path("stimuliGeneration/MainExp/images", img_file)
)
write_json(
cluster_coords_3d,
"mds_data.json",
pretty = TRUE,
auto_unbox = TRUE
)
# =========================
# Export MDS coordinates + stimulus info for 3D website
# =========================
library(dplyr)
library(jsonlite)
# Assumes you already have:
# cluster_coords_3d
# with columns including:
# cluster, D1, D2, D3, nv, rng, sm
# -------------------------
# Build image filenames/paths
# -------------------------
mds_web_data <- cluster_coords_3d %>%
mutate(
nv_str   = paste0("N", nv),
rng_str  = paste0("rng", rng),
s_str    = paste0("curv", sm),
img_file = paste0("circle_", rng_str, "_", nv_str, "_", s_str, "_seed7.png"),
# IMPORTANT:
# this path is relative to the HTML file location
img_path = file.path("stimuliGeneration", "MainExp", "images", img_file),
stimulus_id = paste0("nv", nv, "_rng", rng, "_sm", sm)
) %>%
select(
cluster,
stimulus_id,
D1, D2, D3,
nv, rng, sm,
img_file,
img_path
)
# -------------------------
# Make output folder
# -------------------------
dir.create("mds_site", showWarnings = FALSE)
# -------------------------
# Write JSON
# -------------------------
write_json(
mds_web_data,
path = file.path("mds_site", "mds_data.json"),
pretty = TRUE,
auto_unbox = TRUE
)
cat("Saved JSON to: mds_site/mds_data.json\n")
# =========================================================
# make_colored_stimuli.R
#
# Creates colored versions of transparent stimulus PNGs
# based on their feature values.
#
# INPUT:
#   original PNGs in:
#   stimuliGeneration/MainExp/images
#
# OUTPUT:
#   colored PNGs in:
#   stimuliGeneration/MainExp/images_colored/nv
#   stimuliGeneration/MainExp/images_colored/rng
#   stimuliGeneration/MainExp/images_colored/sm
#
# Assumes filenames look like:
#   circle_rng12_N9_curv0_seed7.png
#   circle_rng25_N17_curv1_seed7.png
#   etc.
#
# This script does NOT touch mds_data.json.
# =========================================================
suppressPackageStartupMessages({
library(magick)
library(stringr)
library(fs)
})
# -----------------------------
# PATHS
# -----------------------------
input_dir  <- "stimuliGeneration/MainExp/images"
output_dir <- "stimuliGeneration/MainExp/images_colored"
output_nv_dir  <- file.path(output_dir, "nv")
output_rng_dir <- file.path(output_dir, "rng")
output_sm_dir  <- file.path(output_dir, "sm")
dir_create(output_nv_dir, recurse = TRUE)
dir_create(output_rng_dir, recurse = TRUE)
dir_create(output_sm_dir, recurse = TRUE)
# -----------------------------
# FIXED COLOR MAPS
# -----------------------------
nv_colors <- c(
`9`  = "#4E79A7",
`17` = "#F28E2B",
`30` = "#59A14F"
)
rng_colors <- c(
`12` = "#4E79A7",
`25` = "#F28E2B",
`45` = "#59A14F"
)
sm_colors <- c(
`0` = "#4E79A7",
`1` = "#F28E2B",
`2` = "#59A14F"
)
# -----------------------------
# HELPER: parse filename
# -----------------------------
parse_features_from_filename <- function(filename) {
# Expected pattern:
# circle_rng12_N9_curv0_seed7.png
pattern <- "circle_rng([0-9]+)_N([0-9]+)_curv([0-9]+)_seed7\\.png$"
m <- str_match(filename, pattern)
if (any(is.na(m))) {
return(NULL)
}
list(
rng = m[2],
nv  = m[3],
sm  = m[4]
)
}
# -----------------------------
# HELPER: recolor PNG while preserving alpha
# -----------------------------
recolor_png_keep_alpha <- function(input_path, output_path, fill_color) {
img <- image_read(input_path)
info <- image_info(img)
width <- info$width[1]
height <- info$height[1]
# solid color base
solid <- image_blank(width = width, height = height, color = fill_color)
# extract alpha from original image
alpha <- image_fx(img, expression = "a")
# copy original alpha onto solid color
colored <- image_composite(solid, alpha, operator = "copyopacity")
image_write(colored, path = output_path, format = "png")
}
# -----------------------------
# GET FILES
# -----------------------------
files <- dir_ls(input_dir, regexp = "\\.png$", type = "file")
if (length(files) == 0) {
stop("No PNG files found in: ", input_dir)
}
cat("Found", length(files), "PNG files.\n")
# -----------------------------
# PROCESS FILES
# -----------------------------
n_done <- 0
n_skipped <- 0
for (input_path in files) {
filename <- path_file(input_path)
parsed <- parse_features_from_filename(filename)
if (is.null(parsed)) {
message("Skipping file with unexpected name format: ", filename)
n_skipped <- n_skipped + 1
next
}
nv_val  <- parsed$nv
rng_val <- parsed$rng
sm_val  <- parsed$sm
nv_color  <- nv_colors[[nv_val]]
rng_color <- rng_colors[[rng_val]]
sm_color  <- sm_colors[[sm_val]]
if (is.null(nv_color) || is.null(rng_color) || is.null(sm_color)) {
message("Skipping file with unmapped feature value: ", filename)
n_skipped <- n_skipped + 1
next
}
out_nv  <- file.path(output_nv_dir, filename)
out_rng <- file.path(output_rng_dir, filename)
out_sm  <- file.path(output_sm_dir, filename)
recolor_png_keep_alpha(input_path, out_nv,  nv_color)
recolor_png_keep_alpha(input_path, out_rng, rng_color)
recolor_png_keep_alpha(input_path, out_sm,  sm_color)
n_done <- n_done + 1
}
# =========================================================
# make_colored_stimuli.R
#
# Creates colored versions of transparent stimulus PNGs
# based on their feature values.
#
# INPUT:
#   stimuliGeneration/MainExp/images
#
# OUTPUT:
#   stimuliGeneration/MainExp/images_colored/nv
#   stimuliGeneration/MainExp/images_colored/rng
#   stimuliGeneration/MainExp/images_colored/sm
#
# Expected filename pattern:
#   circle_rng12_N9_curv0_seed7.png
#   circle_rng25_N18_curv1_seed26.png
#   circle_rng45_N27_curv2_seed10.png
#
# This script does NOT modify mds_data.json.
# =========================================================
suppressPackageStartupMessages({
library(magick)
library(stringr)
library(fs)
})
# -----------------------------
# PATHS
# -----------------------------
input_dir  <- "stimuliGeneration/MainExp/images"
output_dir <- "stimuliGeneration/MainExp/images_colored"
output_nv_dir  <- file.path(output_dir, "nv")
output_rng_dir <- file.path(output_dir, "rng")
output_sm_dir  <- file.path(output_dir, "sm")
dir_create(output_nv_dir, recurse = TRUE)
dir_create(output_rng_dir, recurse = TRUE)
dir_create(output_sm_dir, recurse = TRUE)
# -----------------------------
# FIXED COLOR MAPS
# -----------------------------
# Update these hex colors if you want different ones.
nv_colors <- c(
`9`  = "#4E79A7",
`18` = "#F28E2B",
`27` = "#59A14F"
)
rng_colors <- c(
`12` = "#4E79A7",
`25` = "#F28E2B",
`45` = "#59A14F"
)
sm_colors <- c(
`0` = "#4E79A7",
`1` = "#F28E2B",
`2` = "#59A14F"
)
# -----------------------------
# HELPER: parse filename
# -----------------------------
parse_features_from_filename <- function(filename) {
# Allows any numeric seed
# Example:
# circle_rng12_N18_curv2_seed26.png
pattern <- "^circle_rng([0-9]+)_N([0-9]+)_curv([0-9]+)_seed([0-9]+)\\.png$"
m <- str_match(filename, pattern)
if (any(is.na(m))) {
return(NULL)
}
list(
rng  = m[2],
nv   = m[3],
sm   = m[4],
seed = m[5]
)
}
# -----------------------------
# HELPER: recolor PNG while preserving alpha
# -----------------------------
recolor_png_keep_alpha <- function(input_path, output_path, fill_color) {
img <- image_read(input_path)
info <- image_info(img)
width <- info$width[1]
height <- info$height[1]
# Solid color base
solid <- image_blank(width = width, height = height, color = fill_color)
# Extract alpha from original image
alpha <- image_fx(img, expression = "a")
# Copy original alpha onto solid color
colored <- image_composite(solid, alpha, operator = "copyopacity")
image_write(colored, path = output_path, format = "png")
}
# -----------------------------
# GET FILES
# -----------------------------
files <- dir_ls(input_dir, regexp = "\\.png$", type = "file")
if (length(files) == 0) {
stop("No PNG files found in: ", input_dir)
}
cat("Found", length(files), "PNG files.\n")
# -----------------------------
# PROCESS FILES
# -----------------------------
n_done <- 0
n_skipped <- 0
for (input_path in files) {
filename <- path_file(input_path)
parsed <- parse_features_from_filename(filename)
if (is.null(parsed)) {
message("Skipping file with unexpected name format: ", filename)
n_skipped <- n_skipped + 1
next
}
nv_val  <- parsed$nv
rng_val <- parsed$rng
sm_val  <- parsed$sm
nv_color  <- nv_colors[[nv_val]]
rng_color <- rng_colors[[rng_val]]
sm_color  <- sm_colors[[sm_val]]
if (is.null(nv_color) || is.null(rng_color) || is.null(sm_color)) {
message("Skipping file with unmapped feature value: ", filename)
n_skipped <- n_skipped + 1
next
}
out_nv  <- file.path(output_nv_dir, filename)
out_rng <- file.path(output_rng_dir, filename)
out_sm  <- file.path(output_sm_dir, filename)
recolor_png_keep_alpha(input_path, out_nv,  nv_color)
recolor_png_keep_alpha(input_path, out_rng, rng_color)
recolor_png_keep_alpha(input_path, out_sm,  sm_color)
n_done <- n_done + 1
}
# -----------------------------
# SUMMARY
# -----------------------------
cat("\nDone.\n")
cat("Processed:", n_done, "files\n")
cat("Skipped:", n_skipped, "files\n")
cat("\nCreated folders:\n")
cat(" -", output_nv_dir, "\n")
cat(" -", output_rng_dir, "\n")
cat(" -", output_sm_dir, "\n")
