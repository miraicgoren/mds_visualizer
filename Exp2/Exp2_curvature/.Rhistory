group_by(subj_id) %>%
summarise(
n_failed_blocks = sum(blockUse == 0),  # Count blocks where blockUse = 0
subUse = if_else(n_failed_blocks > 3, 0, 1),  # Flag: 0 if >3 failed, else 1
.groups = "drop"
)
# View results
subject_quality
subject_quality %>%
count(subUse)
# Add subUse flag to original data frame
df_raw_all <- df_raw_all %>%
left_join(subject_quality %>% select(subj_id, subUse),
by = "subj_id") %>%
left_join(block_catch_summary %>% select(subj_id, block_index, blockUse),
by = c("subj_id", "block_index"))
# Checking the RT warnings (= RTs faster than 500)
rt_warnings <- df_raw_all %>%
filter(trial_kind == "rt_warning") %>%
count(subj_id)
rt_warnings
df_raw_all %>%
filter(rt < 500) %>%
select(subj_id, rt, block_index, trial_in_block, trial_kind)
# Calculate total percentage of trials excluded
exclusion_summary <- df_raw_all %>%
filter(subUse == 1,  # Only subjects with subUse = 1
trial_kind %in% c('exp_111', 'exp_221')) %>%  # Only these trial types
group_by(subj_id) %>%
summarise(
total_trials = n(),  # Total trials before exclusion
excluded_trials = sum(blockUse == 0 | rt < 500, na.rm = TRUE),  # Excluded trials
included_trials = sum(blockUse == 1 & rt >= 500, na.rm = TRUE),  # Included trials
.groups = "drop"
)
# Calculate overall exclusion percentage
overall_exclusion <- exclusion_summary %>%
summarise(
total_trials_all = sum(total_trials),
total_excluded = sum(excluded_trials),
total_included = sum(included_trials),
exclusion_pct = (total_excluded / total_trials_all) * 100
)
# View results
overall_exclusion
# Leave only the trials for analysis
df_trials <- df_raw_all %>%
filter(subUse == 1,  # Only subjects with subUse = 1
blockUse == 1,
rt >= 500,
trial_kind %in% c('exp_111', 'exp_221'))  # Only these trial types
# each row = one item in the triad.
df_items <- df_trials %>%
group_by(subj_id) %>%
mutate(triad_id = row_number()) %>%
ungroup() %>%
select(
subj_id, triad_id, chosen_index,
stim_left, stim_middle, stim_right
) %>%
pivot_longer(
cols = c(stim_left, stim_middle, stim_right),
names_to = "position",
values_to = "stim_path"
) %>%
mutate(
pos_index = case_when(
position == "stim_left"   ~ 0L,
position == "stim_middle" ~ 1L,
position == "stim_right"  ~ 2L
),
choice = as.integer(pos_index == chosen_index),
is_chosen = pos_index == chosen_index,
rng  = as.integer(str_match(stim_path, "circle_rng(\\d+)_")[,2]),
N    = as.integer(str_match(stim_path, "N(\\d+)_curv")[,2]),
sm   = as.numeric(str_match(stim_path, "curv([0-9.]+)_seed")[,2]),
seed = as.integer(str_match(stim_path, "seed(\\d+)")[,2])
)
head(df_items)
# Alternative-Specific (Long) Format
# one row per alternative (item) per choice set (triad)
# the choice depends on which item is most different, not the absolute attribute
# values. By centering on the triad mean, we are explicitly modeling "how odd is this
# item?"
alt_data_diff <- df_items %>%
group_by(subj_id, triad_id) %>%
mutate(   # deviation from the triad mean
sm_dev = abs(sm - mean(sm)),
N_dev   = abs(N - mean(N)),
rng_dev  = abs(rng - mean(rng))
) %>%
ungroup() %>%
mutate(trial_id = paste0(subj_id, "_", triad_id)) %>%
mutate(   # standardizes by the max deviation (makes attributes relative/comparative)
sm_dev_s = sm_dev / max(sm_dev),
N_dev_s   = N_dev   / max(N_dev),
rng_dev_s  = rng_dev  / max(rng_dev)
) %>%
select(subj_id, trial_id, pos_index, choice,
sm_dev_s, N_dev_s, rng_dev_s)
# Convert to mlogit format
mlogit_data <- mlogit.data(
data = alt_data_diff,
shape = "long",
choice = "choice",
chid.var = "trial_id",
alt.var = "pos_index",
id.var = "subj_id"
)
# Fit multinomial logit model
# coefficient signs positive = more likely to choose (larger deviation = more "odd")
# No individual-specific variables with alternative-specific effects
# No individual-specific variables with generic effects
model_m <- gmnl(
choice ~ sm_dev_s + N_dev_s + rng_dev_s | 0 | 0 | 0,
data = mlogit_data,
model = "mixl",
ranp = c(            # random slopes for each attribute across subjects
sm_dev_s = "n",
N_dev_s   = "n",
rng_dev_s  = "n"
),
panel = TRUE
)
summary(model_m)
# Fixed Effects (Mean Coefficients)
# Random Effects (Standard Deviations)
# Extract normalized weights
beta_hat <- coef(model_m)
beta_mean <- beta_hat[c("sm_dev_s", "N_dev_s", "rng_dev_s")]
weights_mnl <- abs(beta_mean) / sum(abs(beta_mean))
weights_mnl
# --- GLOBAL SETTINGS ---
# Define consistent levels and colors for all plots
feat_levels <- c("Smoothness", "NV", "Range")
# 1. Extract Fixed Effects (Mean Coefficients)
# We filter for the mean parameters, ignoring the 'sd.' parameters
beta_est <- coef(model_m)[c("sm_dev_s", "N_dev_s", "rng_dev_s")]
beta_se  <- sqrt(diag(vcov(model_m)))[c("sm_dev_s", "N_dev_s", "rng_dev_s")]
df_fixed <- data.frame(
Feature = names(beta_est),
Estimate = as.numeric(beta_est),
SE = as.numeric(beta_se)
) %>%
mutate(
Lower = Estimate - 1.96 * SE,
Upper = Estimate + 1.96 * SE,
# Clean names for plotting
Feature = factor(Feature, levels = c("sm_dev_s", "N_dev_s", "rng_dev_s"),
labels = feat_levels)
)
# Plot: Mean Effects
ggplot(df_fixed, aes(x = Feature, y = Estimate, fill = Feature)) +
# Bar plot
geom_col(width = 0.6, color = "black") +
# Error bars (95% CI)
geom_errorbar(aes(ymin = Lower, ymax = Upper), width = 0.2, linewidth = 0.8) +
# Classic theme (removes grid lines and background)
theme_classic(base_size = 14) +
# Labels
labs(
title = "Population Mean Sensitivity",
subtitle = "Higher estimates = stronger preference for the deviant item",
x = NULL,
y = "Log-Odds Estimate (Mean Beta)"
) +
scale_y_continuous(expand = c(0, 0), limits = c(0, max(df_fixed$Upper) * 1.1))+
theme(legend.position = "none")
# 2. Extract Individual Conditional Means (Corrected)
features_raw <- c("sm_dev_s", "N_dev_s", "rng_dev_s")
df_indiv <- do.call(rbind, lapply(1:3, function(i) {
eff <- effect.gmnl(model_m, par = features_raw[i], effect = "ce")
# create data frame without relying on row names
data.frame(
Value = as.numeric(eff$mean),  # Flattens the matrix/vector
Feature = feat_levels[i]
)
}))
df_indiv$Feature <- factor(df_indiv$Feature, levels = feat_levels)
# Plot: Density Distributions of Subject Strategies
ggplot(df_indiv, aes(x = Value, fill = Feature)) +
geom_density(alpha = 0.5) +
geom_vline(xintercept = 0, linetype = "dashed") +
facet_wrap(~Feature, scales = "free") +
theme_minimal(base_size = 14) +
labs(
title = "Heterogeneity in Strategy",
subtitle = "Distribution of individual subject coefficients",
x = "Individual Sensitivity (Beta)",
y = "Density"
) +
theme(legend.position = "none")
# 3. Predicted Probability Curve (Marginal Effect)
# Function to calculate Logit Probability for a standardized deviation x (0 to 1)
# Assumes a 3-choice task where other 2 items have 0 deviation (baseline)
predict_prob <- function(beta, x_vals) {
# Utility of target = beta * x
# Utility of distractors = beta * 0 = 0
# Prob = exp(u_target) / (exp(u_target) + exp(0) + exp(0))
exp(beta * x_vals) / (exp(beta * x_vals) + 1 + 1)
}
# Create a sequence of deviations from 0 to 1
x_seq <- seq(0, 1, length.out = 100)
# Generate curves for the Mean Observer
df_pred <- data.frame()
for(i in 1:3) {
probs <- predict_prob(beta_est[i], x_seq)
df_pred <- rbind(df_pred, data.frame(
Deviation = x_seq,
Probability = probs,
Feature = feat_levels[i]
))
}
df_pred$Feature <- factor(df_pred$Feature, levels = feat_levels)
# Plot: Sensitivity Curves
ggplot(df_pred, aes(x = Deviation, y = Probability, color = Feature)) +
geom_line(linewidth = 1.2) +
geom_hline(yintercept = 1/3, linetype = "dotted") +
scale_y_continuous(limits = c(0.3, 1), labels = scales::percent) +
theme_minimal(base_size = 14) +
labs(
title = "Behavioral Sensitivity (Mean Observer)",
x = "Standardized Deviation (0 = Mean, 1 = Max)",
y = "Probability of Choosing Item"
)
#Using MNL weights for clustering
library(cluster)   # for silhouette
library(factoextra) # for cluster visualization
# =========================
# 1. Fit per-subject MNL to get weights
# =========================
# Extract subject IDs
subj_ids <- unique(alt_data_diff$subj_id)
# Function to compute empirical odds per subject
subject_weights <- lapply(subj_ids, function(s) {
dat_subj <- alt_data_diff %>% filter(subj_id == s)
# Fit multinomial logit for this subject only
m_subj <- mlogit(choice ~ sm_dev_s + N_dev_s + rng_dev_s | 0,
data = mlogit.data(dat_subj, shape="long", choice="choice",
chid.var="trial_id", alt.var="pos_index"))
beta <- coef(m_subj)
tibble(
subj_id = s,
sm   = beta["sm_dev_s"],
N     = beta["N_dev_s"],
rng    = beta["rng_dev_s"]
)
})
weights_df <- bind_rows(subject_weights)
# Normalize weights per subject
weights_df <- weights_df %>%
rowwise() %>%
mutate(
total = sum(abs(c(sm, N, rng))),
sm = sm / total,
N   = N   / total,
rng  = rng  / total
) %>%
select(-total)
# =========================
# 2. Choosing the optimal number of clusters
# =========================
# Convert to matrix
weight_mat <- as.matrix(weights_df %>% select(sm, N, rng))
set.seed(4228)
# Elbow method
fviz_nbclust(weight_mat, kmeans, method = "wss") +
labs(subtitle = "Elbow method")
# Silhouette method
fviz_nbclust(weight_mat, kmeans, method = "silhouette") +
labs(subtitle = "Average silhouette method") # higher = better clustering
# =========================
# 3. Fit k-means with chosen k
# =========================
k_opt <- 2  # replace with chosen number based on elbow/silhouette plots
kres <- kmeans(weight_mat, centers = k_opt, nstart = 25)
weights_df$cluster <- kres$cluster
# =========================
# 4. Visualize clusters
# =========================
fviz_cluster(kres, data = weight_mat, geom = "point", stand = FALSE,
ellipse.type = "convex") +
theme_minimal() +
labs(title = paste("K-means Clustering of Subject Weights (k =", k_opt, ")"))
cluster_means <- weights_df %>%
group_by(cluster) %>%
summarise(
mean_sm = mean(sm, na.rm = TRUE),
mean_N   = mean(N, na.rm = TRUE),
mean_rng  = mean(rng, na.rm = TRUE),
n_subjects = n()
)
cluster_means
weights_df %>%
group_by(cluster) %>%
summarise(across(c(sm, N, rng), mean)) %>%
pivot_longer(cols = c(sm, N, rng), names_to = "attribute", values_to = "mean_value") %>%
# Reorder attributes if needed, e.g., Sm -> NV -> Ang
mutate(attribute = factor(attribute, levels = c("sm", "N", "rng"))) %>%
ggplot(aes(x = factor(cluster), y = mean_value, fill = attribute)) +
geom_bar(stat = "identity", position = "dodge", color = "black", width = 0.7) +
labs(
title = "Mean Weights per Cluster",
x = "Cluster",
y = "Mean Normalized Weight",
fill = "Attribute"
) +
theme_classic(base_size = 14) +
scale_y_continuous(expand = c(0, 0), limits = c(0, NA)) # Bars sit flush on axis
# =========================
# 5. Silhouette score
# =========================
dist_mat <- dist(weight_mat, method = "euclidean")
sil <- silhouette(weights_df$cluster, dist_mat)
mean(sil[, 3])  # average silhouette width
# =========================
# 3. Fit k-means with chosen k
# =========================
k_opt <- 2  # replace with chosen number based on elbow/silhouette plots
