# load data
datapath <- 'data/'
DataFiles <- list.files(path = datapath, pattern = "*.csv", full.names = TRUE)
df_raw_all <- data.frame()
for (k in 1:length(DataFiles)) {
df_temp <- read_csv(
DataFiles[k],
col_types = cols(
rt = col_double(),
response = col_character(),
correct_response = col_character(),
correct = col_logical(),
block_failed = col_logical(),
blocks_failed_total = col_double(),
is_practice = col_logical(),
is_catch = col_logical(),
chosen_N = col_double(),
chosen_curv = col_double(),
.default = col_guess()
),
na = c("", "NA", "null", "NaN")
)
# Extract subject ID from filename
subj_id <- str_match(basename(DataFiles[k]), "Han_curvRep2D_(\\d+)_")[, 2]
df_temp$subj_id <- subj_id
df_raw_all <- bind_rows(df_raw_all, df_temp)
}
df_raw_all <- df_raw_all %>%
select(subj_id = participant, age, sex, rt, stimulus, response, block, block_index, trial_in_block, global_trial_index, trial_kind, pattern, feature_ids, features_triplet, stim_left, stim_middle, stim_right, is_practice, is_catch, correct_response, correct, chosen_index, chosen_stimulus, chosen_N, chosen_range, chosen_curv, chosen_seed)
df_raw_all %>% count(subj_id, trial_kind) %>% arrange(subj_id, desc(n)) %>% filter(trial_kind == "exp_221" | trial_kind == "exp_111")
# in experiment design code, when generating all the possible triplets of the patterns 2/2/2 and 2/1/1, there should have been 324 exp_222 and 216 exp_111. so 540 total, and 75% these triplets should be used. All participants see subset of 405 triplets.
# participants don't all see all the same triplets
# catch trial accuracy for main trials
# main_catch <- df_raw_all %>%
#   filter(trial_kind == "catch")
#
# main_catch %>%
#   group_by(participant) %>%
#   summarise(
#     n_catch = n(),
#     n_correct = sum(correct == TRUE, na.rm = TRUE),
#     accuracy = mean(correct == TRUE, na.rm = TRUE))
# each participant must get 75% catch trial accuracy min in each block to pass that block
block_catch_summary <- df_raw_all %>%
filter(trial_kind == "catch") %>%
group_by(subj_id, block_index) %>%
summarise(
n_catch = n(),
n_correct = sum(correct == TRUE, na.rm = TRUE),
acc = n_correct / n_catch,
blockUse = if_else(acc >= 0.75, 1, 0),  # 1 if acc >= 75%, else 0
.groups = "drop"
)
# Count failed blocks per participant and assign subUse flag
subject_quality <- block_catch_summary %>%
group_by(subj_id) %>%
summarise(
n_failed_blocks = sum(blockUse == 0),  # Count blocks where blockUse = 0
subUse = if_else(n_failed_blocks > 3, 0, 1),  # Flag: 0 if >3 failed, else 1
.groups = "drop"
)
# View results
subject_quality
subject_quality %>%
count(subUse)
# Add subUse flag to original data frame
df_raw_all <- df_raw_all %>%
left_join(subject_quality %>% select(subj_id, subUse),
by = "subj_id") %>%
left_join(block_catch_summary %>% select(subj_id, block_index, blockUse),
by = c("subj_id", "block_index"))
# Checking the RT warnings (= RTs faster than 500)
rt_warnings <- df_raw_all %>%
filter(trial_kind == "rt_warning") %>%
count(subj_id)
rt_warnings
df_raw_all %>%
filter(rt < 500) %>%
select(subj_id, rt, block_index, trial_in_block, trial_kind)
# Calculate total percentage of trials excluded
exclusion_summary <- df_raw_all %>%
filter(subUse == 1,  # Only subjects with subUse = 1
trial_kind %in% c('exp_111', 'exp_221')) %>%  # Only these trial types
group_by(subj_id) %>%
summarise(
total_trials = n(),  # Total trials before exclusion
excluded_trials = sum(blockUse == 0 | rt < 500, na.rm = TRUE),  # Excluded trials
included_trials = sum(blockUse == 1 & rt >= 500, na.rm = TRUE),  # Included trials
.groups = "drop"
)
# Calculate overall exclusion percentage
overall_exclusion <- exclusion_summary %>%
summarise(
total_trials_all = sum(total_trials),
total_excluded = sum(excluded_trials),
total_included = sum(included_trials),
exclusion_pct = (total_excluded / total_trials_all) * 100
)
# View results
overall_exclusion
